{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "version": {
            "default": "2.0",
            "description": "The version of the schema.",
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "number"
                }
            ]
        },
        "summary": {
            "type": "object",
            "properties": {
                "generatePRSummary": {
                    "type": "boolean",
                    "default": true,
                    "description": "Indicates whether to generate a summary for the pull request."
                },
                "customInstructions": {
                    "type": "string",
                    "default": "",
                    "description": "Custom instructions for the pull request review."
                },
                "behaviourForExistingDescription": {
                    "type": "string",
                    "enum": [
                        "replace",
                        "concatenate",
                        "complement"
                    ],
                    "default": "concatenate",
                    "description": "Defines how to handle existing descriptions."
                },
                "behaviourForNewCommits": {
                    "type": "string",
                    "enum": [
                        "none",
                        "replace",
                        "concatenate"
                    ],
                    "default": "none",
                    "description": "Defines how Kody updates the summary when new commits arrive."
                }
            },
            "required": [
                "generatePRSummary",
                "customInstructions",
                "behaviourForExistingDescription",
                "behaviourForNewCommits"
            ],
            "additionalProperties": false
        },
        "ignorePaths": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "default": [
                "yarn.lock",
                "package-lock.json",
                "package.json",
                ".env",
                "**/*.json"
            ],
            "description": "List of file paths to ignore during the review."
        },
        "baseBranches": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "default": [],
            "description": "List of base branches for the pull request."
        },
        "reviewOptions": {
            "type": "object",
            "properties": {
                "security": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable security checks during the review."
                },
                "code_style": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable code style checks during the review."
                },
                "kody_rules": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable Kody rules checks during the review."
                },
                "refactoring": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable refactoring checks during the review."
                },
                "error_handling": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable error handling checks during the review."
                },
                "maintainability": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable maintainability checks during the review."
                },
                "potential_issues": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable checks for potential issues during the review."
                },
                "documentation_and_comments": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable checks for documentation and comments during the review."
                },
                "performance_and_optimization": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable performance and optimization checks during the review."
                },
                "breaking_changes": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable checks for breaking changes during the review."
                },
                "bug": {
                    "type": "boolean",
                    "default": true
                },
                "performance": {
                    "type": "boolean",
                    "default": true
                },
                "cross_file": {
                    "type": "boolean",
                    "default": true
                },
                "business_logic": {
                    "type": "boolean",
                    "default": true
                }
            },
            "required": [],
            "additionalProperties": false
        },
        "suggestionControl": {
            "type": "object",
            "properties": {
                "groupingMode": {
                    "type": "string",
                    "enum": [
                        "minimal",
                        "smart",
                        "full"
                    ],
                    "default": "full",
                    "description": "Defines the grouping mode for suggestions."
                },
                "limitationType": {
                    "type": "string",
                    "enum": [
                        "file",
                        "pr",
                        "severity"
                    ],
                    "default": "pr",
                    "description": "Defines the limitation type for suggestions."
                },
                "maxSuggestions": {
                    "type": "integer",
                    "default": 9,
                    "minimum": 9,
                    "description": "Maximum number of suggestions to provide."
                },
                "severityLevelFilter": {
                    "type": "string",
                    "enum": [
                        "critical",
                        "high",
                        "medium",
                        "low"
                    ],
                    "default": "medium",
                    "description": "Filter for the severity level of suggestions."
                },
                "applyFiltersToKodyRules": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether to apply all filters (severity and quantity) to Kody Rules. When false, Kody Rules ignore all filters."
                },
                "severityLimits": {
                    "type": "object",
                    "properties": {
                        "low": {
                            "type": "integer",
                            "default": 0,
                            "minimum": 0,
                            "description": "Maximum number of low severity suggestions."
                        },
                        "medium": {
                            "type": "integer",
                            "default": 0,
                            "minimum": 0,
                            "description": "Maximum number of medium severity suggestions."
                        },
                        "high": {
                            "type": "integer",
                            "default": 0,
                            "minimum": 0,
                            "description": "Maximum number of high severity suggestions."
                        },
                        "critical": {
                            "type": "integer",
                            "default": 0,
                            "minimum": 0,
                            "description": "Maximum number of critical severity suggestions."
                        }
                    },
                    "required": [
                        "low",
                        "medium",
                        "high",
                        "critical"
                    ],
                    "additionalProperties": false,
                    "description": "Limits for suggestions by severity level. Only used when limitationType is 'severity'."
                }
            },
            "required": [
                "groupingMode",
                "limitationType",
                "maxSuggestions",
                "severityLevelFilter"
            ],
            "additionalProperties": false,
            "if": {
                "properties": {
                    "limitationType": {
                        "const": "file"
                    }
                }
            },
            "then": {
                "properties": {
                    "maxSuggestions": {
                        "type": "integer",
                        "maximum": 20
                    }
                }
            },
            "else": {
                "properties": {}
            }
        },
        "ignoredTitleKeywords": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "default": [],
            "description": "List of keywords to ignore in the title."
        },
        "automatedReviewActive": {
            "type": "boolean",
            "default": true,
            "description": "Indicates whether automated review processes are currently active. A value of true means that automated reviews are enabled, while false means they are disabled."
        },
        "showStatusFeedback": {
            "type": "boolean",
            "default": true,
            "description": "Indicates whether Kody should send skip/error status feedback using emoji reactions or comments."
        },
        "pullRequestApprovalActive": {
            "type": "boolean",
            "default": false,
            "description": "Indicates whether pull request approvals are currently active. A value of true means that pull request approvals are enabled, while false means they are disabled."
        },
        "isRequestChangesActive": {
            "type": "boolean",
            "default": false,
            "description": "Indicates whether to change status to 'Request Changes' if a critical suggestions is found."
        },
        "runOnDraft": {
            "type": "boolean",
            "default": true,
            "description": "Indicates whether the review should run on draft pull requests."
        },
        "crossFileDependenciesAnalysis": {
            "type": "boolean",
            "default": true,
            "description": "Indicates whether Kody should collect and use cross-file dependency context during code review."
        },
        "kodusConfigFileOverridesWebPreferences": {
            "type": "boolean",
            "default": false,
            "description": "Whether repository kodus config files override web preferences."
        },
        "reviewCadence": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "automatic",
                        "manual",
                        "auto_pause"
                    ],
                    "default": "automatic"
                },
                "timeWindow": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 15
                },
                "pushesToTrigger": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 3
                }
            },
            "required": [
                "type"
            ],
            "additionalProperties": false
        },
        "enableCommittableSuggestions": {
            "type": "boolean",
            "default": true,
            "description": "Whether Kody may generate committable suggestions."
        },
        "codeReviewVersion": {
            "type": "string",
            "enum": [
                "legacy",
                "v2",
                "v3-agent"
            ],
            "default": "v2"
        },
        "ideRulesSyncEnabled": {
            "type": "boolean",
            "default": false
        },
        "ideSyncDisableAction": {
            "type": "string",
            "enum": [
                "keep",
                "pause",
                "delete"
            ],
            "default": "keep"
        },
        "kodyRulesGeneratorEnabled": {
            "type": "boolean",
            "default": true
        },
        "llmGeneratedMemoriesRequireApproval": {
            "type": "boolean",
            "default": false
        },
        "customMessages": {
            "type": "object",
            "properties": {
                "globalSettings": {
                    "type": "object",
                    "properties": {
                        "hideComments": {
                            "type": "boolean",
                            "default": false
                        },
                        "suggestionCopyPrompt": {
                            "type": "boolean",
                            "default": true
                        }
                    },
                    "additionalProperties": false
                },
                "startReviewMessage": {
                    "type": "object",
                    "properties": {
                        "status": {
                            "type": "string",
                            "enum": [
                                "every_push",
                                "only_when_opened",
                                "off",
                                "active",
                                "inactive"
                            ],
                            "default": "every_push"
                        },
                        "content": {
                            "type": "string",
                            "default": ""
                        }
                    },
                    "additionalProperties": false
                },
                "endReviewMessage": {
                    "type": "object",
                    "properties": {
                        "status": {
                            "type": "string",
                            "enum": [
                                "every_push",
                                "only_when_opened",
                                "off",
                                "active",
                                "inactive"
                            ],
                            "default": "every_push"
                        },
                        "content": {
                            "type": "string",
                            "default": ""
                        }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        },
        "v2PromptOverrides": {
            "type": "object",
            "properties": {
                "categories": {
                    "type": "object",
                    "properties": {
                        "descriptions": {
                            "type": "object",
                            "properties": {
                                "bug": {
                                    "type": "string"
                                },
                                "performance": {
                                    "type": "string"
                                },
                                "security": {
                                    "type": "string"
                                }
                            },
                            "additionalProperties": false
                        }
                    },
                    "additionalProperties": false
                },
                "severity": {
                    "type": "object",
                    "properties": {
                        "flags": {
                            "type": "object",
                            "properties": {
                                "critical": {
                                    "type": "string"
                                },
                                "high": {
                                    "type": "string"
                                },
                                "medium": {
                                    "type": "string"
                                },
                                "low": {
                                    "type": "string"
                                }
                            },
                            "additionalProperties": false
                        }
                    },
                    "additionalProperties": false
                },
                "level": {
                    "type": "object",
                    "properties": {
                        "critical": {
                            "type": "string"
                        },
                        "issue": {
                            "type": "string"
                        },
                        "warning": {
                            "type": "string"
                        }
                    },
                    "additionalProperties": false
                },
                "generation": {
                    "type": "object",
                    "properties": {
                        "main": {
                            "type": "string"
                        }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        }
    },
    "required": [
        "version",
        "summary",
        "ignorePaths",
        "baseBranches",
        "reviewOptions",
        "suggestionControl",
        "ignoredTitleKeywords",
        "automatedReviewActive",
        "pullRequestApprovalActive",
        "isRequestChangesActive",
        "runOnDraft"
    ],
    "additionalProperties": false
}
